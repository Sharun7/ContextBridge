# ContextBridge Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Google Gemini API Key
# ============================================
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# DEMO MODE
# ============================================
# Set to true to use mock data, false to use real API integrations
DEMO_MODE=true

# ============================================
# SLACK INTEGRATION (Optional - for real data)
# ============================================
# Get tokens from: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# ============================================
# JIRA INTEGRATION (Optional - for real data)
# ============================================
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# ============================================
# GOOGLE DRIVE INTEGRATION (Optional - for real data)
# ============================================
# Path to OAuth2 credentials JSON file or service account JSON
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/drive_credentials.json
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=./credentials/drive_service_account.json

# ============================================
# GMAIL INTEGRATION (Optional - for real data)
# ============================================
# Path to OAuth2 credentials JSON file or service account JSON
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json
GMAIL_SERVICE_ACCOUNT_PATH=./credentials/gmail_service_account.json

# ============================================
# STORAGE CONFIGURATION
# ============================================
CHROMA_PERSIST_DIR=./chroma_db
DATABASE_URL=sqlite:///./contextbridge.db

# ============================================
# API CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# AI CONFIGURATION
# ============================================
GEMINI_MODEL=gemini-2.5-flash
EXTRACTION_BATCH_SIZE=10
EXTRACTION_DELAY_MS=500

# ============================================
# ALERT CONFIGURATION
# ============================================
ALERT_CONFIDENCE_THRESHOLD=60
ALERT_MIN_IMPORTANCE_SCORE=6
