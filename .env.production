# Production Environment Variables for Backend
# Copy this to your Render dashboard as environment variables

# Python Configuration
PYTHON_VERSION=3.11.0
ENVIRONMENT=production
DEBUG=False

# Database Configuration
DATABASE_URL=sqlite:///./data/contextbridge.db

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/chroma_db

# Ollama Configuration (if using local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# OR use OpenAI instead (recommended for free tier)
# USE_OPENAI=True
# OPENAI_API_KEY=your-openai-api-key-here

# CORS Configuration (update with your frontend URL)
CORS_ORIGINS=https://contextbridge-frontend.onrender.com,http://localhost:3000

# API Configuration
API_HOST=0.0.0.0
